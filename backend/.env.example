# Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
MONGODBURL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority

# URL of the deployed FastAPI ML service (e.g. https://partimepal-ml.onrender.com)
ML_SERVICE_URL=http://127.0.0.1:8000

# URL of the deployed frontend (e.g. https://partimepal-frontend.onrender.com)
FRONTEND_URL=http://localhost:5173

# Server port (Render sets this automatically, leave blank locally)
# PORT=5000

NODE_ENV=development
